{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Islam Pro",
  "version": "1.0.0",
  "identifier": "com.islampro.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8081",
    "beforeDevCommand": "pnpm web",
    "beforeBuildCommand": "pnpm exec expo export --platform web"
  },
  "app": {
    "windows": [
      {
        "title": "Islam Pro",
        "width": 1000,
        "height": 720,
        "minWidth": 700,
        "minHeight": 520,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "macOS": {
      "dmg": {
        "background": "dmg-background.png",
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    }
  }
}
