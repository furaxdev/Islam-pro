{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Islam Pro",
  "version": "1.0.0",
  "identifier": "com.islampro.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8081",
    "beforeDevCommand": "yarn web",
    "beforeBuildCommand": "yarn expo export --platform web"
  },
  "app": {
    "windows": [
      {
        "title": "Islam Pro",
        "width": 440,
        "height": 900,
        "minWidth": 380,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
